{
  "manifest_version": 3,
  "name": "ChatGPT Message Markdown Exporter",
  "version": "0.2.0",
  "description": "Add Export Markdown button to every ChatGPT message.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["lib/html2canvas.min.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
